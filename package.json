{
  "name": "artistic-git",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm git-toolchain:ensure && vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "pnpm git-toolchain:ensure && tsc && vite build && node scripts/check-production-e2e-boundary.mjs",
    "build:e2e": "pnpm git-toolchain:ensure && tsc && vite build --mode e2e",
    "preview": "vite preview",
    "test": "pnpm git-toolchain:ensure && vitest run",
    "test:watch": "pnpm git-toolchain:ensure && vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e:check": "tsc --noEmit -p e2e/tsconfig.json && node scripts/check-e2e-real-ui.mjs && node scripts/phase12-e2e-full-chain-audit.mjs --check",
    "e2e:build:contract:test": "node --test scripts/e2e-build-contract.node-tests.mjs scripts/check-production-e2e-boundary.node-tests.mjs",
    "e2e:tauri": "pnpm git-toolchain:ensure && pnpm e2e:check && wdio run ./wdio.tauri.conf.ts --tsConfigPath=./e2e/tsconfig.json",
    "e2e:tauri:ci": "pnpm git-toolchain:ensure && pnpm e2e:check && wdio run ./wdio.tauri.conf.ts --tsConfigPath=./e2e/tsconfig.json",
    "e2e:real-git:report": "pnpm git-toolchain:ensure && node scripts/e2e-real-git-report.mjs && pnpm -s phase12:e2e:audit",
    "e2e:real-git:report:test": "node --test scripts/e2e-real-git-report.node-tests.mjs",
    "git-toolchain:ensure": "node scripts/ensure-git-toolchain.mjs",
    "git-toolchain:verify": "node scripts/check-git-dist.mjs",
    "git-toolchain:build:test": "node --test scripts/atomic-directory-publish.node-tests.mjs scripts/build-git-toolchain-helpers.node-tests.mjs scripts/fetch-git-dist.node-tests.mjs scripts/windows-git-dist-pruning.node-tests.mjs",
    "git-toolchain:config:check": "node scripts/check-git-toolchain-config.mjs",
    "git-toolchain:state:test": "node --test scripts/git-toolchain-state.node-tests.mjs",
    "git-toolchain:update": "node scripts/update-git-toolchain.mjs",
    "git:push-safety:check": "node scripts/check-no-force-push.mjs",
    "accessibility:audit": "node scripts/check-accessibility-audit.mjs",
    "i18n:audit": "node scripts/check-i18n-audit.mjs",
    "privacy:audit": "node scripts/check-privacy-network.mjs",
    "privacy:audit:test": "node --test scripts/check-privacy-network.node-tests.mjs",
    "phase9:close-guard:audit": "node scripts/check-phase9-close-guard-audit.mjs",
    "phase9:crash-isolation:audit": "node scripts/check-phase9-crash-isolation-audit.mjs",
    "release:version": "node scripts/release-version.mjs",
    "release:version:test": "node --test scripts/release-version.node-tests.mjs",
    "release:updater-pubkey": "node scripts/apply-tauri-updater-public-key.mjs",
    "release:updater-pubkey:test": "node --test scripts/apply-tauri-updater-public-key.node-tests.mjs",
    "release:latest-json": "node scripts/generate-tauri-latest-json.mjs",
    "release:artifacts:test": "node --test scripts/optimize-macos-release-bundles.node-tests.mjs scripts/repack-deb.node-tests.mjs scripts/release-artifacts.node-tests.mjs",
    "release:resources:check": "node scripts/check-tauri-bundle-resources.mjs --require-manifest",
    "release:check": "pnpm git-toolchain:ensure && pnpm git-toolchain:state:test && pnpm git-toolchain:build:test && pnpm size:audit:test && pnpm release:version:test && pnpm release:updater-pubkey:test && pnpm release:artifacts:test && pnpm release:rehearsal:checklist:test && pnpm e2e:build:contract:test && pnpm e2e:real-git:report:test && pnpm phase12:perf:test && pnpm phase12:evidence:test && pnpm readiness:summary:test && pnpm release:resources:check",
    "release:rehearsal:checklist": "node scripts/release-rehearsal-checklist.mjs",
    "release:rehearsal:checklist:test": "node --test scripts/release-rehearsal-checklist.node-tests.mjs",
    "readiness:summary": "node scripts/readiness-summary.mjs",
    "readiness:summary:test": "node --test scripts/readiness-summary.node-tests.mjs",
    "size:audit:test": "node --test scripts/size-audit.node-tests.mjs",
    "phase12:e2e:audit": "node scripts/phase12-e2e-full-chain-audit.mjs",
    "phase12:e2e:finalize": "node scripts/phase12-e2e-finalize.mjs",
    "phase12:evidence:summary": "node scripts/phase12-evidence-summary.mjs",
    "phase12:evidence:test": "node --test scripts/phase12-evidence-report.node-tests.mjs",
    "phase12:failure-matrix": "node scripts/phase12-failure-matrix.mjs",
    "phase12:perf": "pnpm git-toolchain:ensure && node scripts/phase12-perf-verify.mjs",
    "phase12:perf:heavy": "pnpm git-toolchain:ensure && node scripts/phase12-perf-verify.mjs --heavy",
    "phase12:perf:test": "node --test scripts/phase12-perf-verify.node-tests.mjs",
    "tauri": "tauri",
    "tauri:dev": "pnpm git-toolchain:ensure && tauri dev",
    "tauri:build": "pnpm git-toolchain:ensure && tauri build --config src-tauri/tauri.local.conf.json",
    "bindings:generate": "cargo run -p artistic-git-app --bin export-bindings && pnpm exec prettier --write src/lib/ipc/generated.ts",
    "bindings:check": "pnpm bindings:generate && git diff --exit-code -- src/lib/ipc/generated.ts",
    "cargo:test": "pnpm git-toolchain:ensure && cargo test --workspace",
    "cargo:fmt": "cargo fmt --all --check",
    "cargo:clippy": "cargo clippy --workspace --all-targets -- -D warnings"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "webdriverio": "^9.29.1"
  }
}
