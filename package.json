{
  "name": "artistic-git",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e:check": "tsc --noEmit -p e2e/tsconfig.json && node scripts/check-e2e-real-ui.mjs && node scripts/phase12-e2e-full-chain-audit.mjs --check",
    "e2e:tauri": "pnpm e2e:check && wdio run ./wdio.tauri.conf.ts --tsConfigPath=./e2e/tsconfig.json",
    "e2e:tauri:ci": "pnpm e2e:check && wdio run ./wdio.tauri.conf.ts --tsConfigPath=./e2e/tsconfig.json",
    "e2e:real-git:report": "node scripts/e2e-real-git-report.mjs && pnpm -s phase12:e2e:audit",
    "e2e:real-git:report:test": "node --test scripts/e2e-real-git-report.node-tests.mjs",
    "git-dist:check": "node scripts/check-git-dist.mjs --schema-only",
    "git-dist:check:real": "node scripts/check-git-dist.mjs --schema-only --real-build --expect-placeholder-rejection",
    "git-dist:report": "node scripts/git-dist-report.mjs",
    "git-dist:test": "node --test scripts/git-dist.node-tests.mjs",
    "git:push-safety:check": "node scripts/check-no-force-push.mjs",
    "accessibility:audit": "node scripts/check-accessibility-audit.mjs",
    "i18n:audit": "node scripts/check-i18n-audit.mjs",
    "privacy:audit": "node scripts/check-privacy-network.mjs",
    "phase9:close-guard:audit": "node scripts/check-phase9-close-guard-audit.mjs",
    "phase9:crash-isolation:audit": "node scripts/check-phase9-crash-isolation-audit.mjs",
    "fetch:git-dist": "node scripts/fetch-git-dist.mjs",
    "release:version": "node scripts/release-version.mjs",
    "release:version:test": "node --test scripts/release-version.node-tests.mjs",
    "release:updater-pubkey": "node scripts/apply-tauri-updater-public-key.mjs",
    "release:updater-pubkey:test": "node --test scripts/apply-tauri-updater-public-key.node-tests.mjs",
    "release:latest-json": "node scripts/generate-tauri-latest-json.mjs",
    "release:artifacts:test": "node --test scripts/release-artifacts.node-tests.mjs",
    "release:git-dist-build-evidence:test": "node --test scripts/verify-git-dist-build-evidence.node-tests.mjs",
    "release:resources:check": "node scripts/check-tauri-bundle-resources.mjs",
    "release:check": "pnpm release:version:test && pnpm release:updater-pubkey:test && pnpm release:artifacts:test && pnpm release:git-dist-build-evidence:test && pnpm release:rehearsal:checklist:test && pnpm release:resources:check",
    "release:rehearsal:checklist": "node scripts/release-rehearsal-checklist.mjs",
    "release:rehearsal:checklist:test": "node --test scripts/release-rehearsal-checklist.node-tests.mjs",
    "phase12:e2e:audit": "node scripts/phase12-e2e-full-chain-audit.mjs",
    "phase12:e2e:finalize": "node scripts/phase12-e2e-finalize.mjs",
    "phase12:evidence:summary": "node scripts/phase12-evidence-summary.mjs",
    "phase12:evidence:test": "node --test scripts/phase12-evidence-report.node-tests.mjs scripts/activate-phase12-git-dist.node-tests.mjs",
    "phase12:git-dist:activate:test": "node --test scripts/activate-phase12-git-dist.node-tests.mjs",
    "phase12:failure-matrix": "node scripts/phase12-failure-matrix.mjs",
    "phase12:perf": "node scripts/phase12-perf-verify.mjs",
    "phase12:perf:heavy": "node scripts/phase12-perf-verify.mjs --heavy --require-real-git-dist",
    "phase12:perf:test": "node --test scripts/phase12-perf-verify.node-tests.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "bindings:generate": "cargo run -p artistic-git-app --bin export-bindings && pnpm exec prettier --write src/lib/ipc/generated.ts",
    "bindings:check": "pnpm bindings:generate && git diff --exit-code -- src/lib/ipc/generated.ts",
    "cargo:test": "cargo test --workspace",
    "cargo:fmt": "cargo fmt --all --check",
    "cargo:clippy": "cargo clippy --workspace --all-targets -- -D warnings"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-service": "^1.2.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "webdriverio": "^9.29.1"
  }
}
