{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeBuildCommand": "pnpm build:e2e"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "wdio-e2e",
          "description": "WDIO bridge available only in debug E2E builds",
          "windows": ["*"],
          "permissions": ["wdio:default", "wdio-webdriver:default"]
        }
      ]
    }
  }
}
